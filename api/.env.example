# For Vercel Postgres / Neon / Supabase / Railway
DATABASE_URL=postgresql://user:password@localhost:5432/delayed

# Frontend origins allowed to call the API
CORS_ORIGINS=http://localhost:3000,https://your-frontend-project.vercel.app

# Optional. Vercel automatically sends this as a Bearer token for cron jobs.
CRON_SECRET=replace-me

# Optional demo user id used by the watch log
DEFAULT_USER_ID=demo

# When true, read endpoints will try one live sync for the requested date if the DB is empty
AUTO_SYNC_ON_EMPTY=true
